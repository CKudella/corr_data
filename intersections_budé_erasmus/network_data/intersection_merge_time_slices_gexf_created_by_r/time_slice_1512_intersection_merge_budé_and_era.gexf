<?xml version="1.0" encoding="UTF-8"?>
<gexf xmlns="http://www.gexf.net/1.3" xmlns:viz="http://www.gexf.net/1.3/viz" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.gexf.net/1.3 http://www.gexf.net/1.3/gexf.xsd" version="1.3">
  <meta lastmodifieddate="2026-07-14">
    <creator>Christoph Kudella</creator>
    <description>A graph representing the intersection between Erasmus's and Budé's networks of correspondence in the year 1512</description>
    <keywords/>
  </meta>
  <graph mode="static" defaultedgetype="directed">
    <attributes class="node" mode="static">
      <attribute id="att1" title="Degree" type="float"/>
      <attribute id="att2" title="colour" type="string"/>
      <attribute id="att3" title="Weighted.Degree" type="float"/>
    </attributes>
    <nodes>
      <node id="1" label="Josse Bade">
        <attvalues>
          <attvalue for="att1" value="1"/>
          <attvalue for="att2" value="#C3161F"/>
          <attvalue for="att3" value="1"/>
        </attvalues>
        <viz:color r="195" g="22" b="31" a="1"/>
        <viz:position x="40.1035036911358" y="-250" z="0"/>
        <viz:size value="125"/>
      </node>
      <node id="2" label="Guillaume Cop">
        <attvalues>
          <attvalue for="att1" value="1"/>
          <attvalue for="att2" value="#C3161F"/>
          <attvalue for="att3" value="1"/>
        </attvalues>
        <viz:color r="195" g="22" b="31" a="1"/>
        <viz:position x="-40.2360956048423" y="250" z="0"/>
        <viz:size value="125"/>
      </node>
      <node id="3" label="Guillaume Budé">
        <attvalues>
          <attvalue for="att1" value="1"/>
          <attvalue for="att2" value="#D5AB5B"/>
          <attvalue for="att3" value="1"/>
        </attvalues>
        <viz:color r="213" g="171" b="91" a="1"/>
        <viz:position x="-250" y="121.908459258511" z="0"/>
        <viz:size value="125"/>
      </node>
      <node id="4" label="Desiderius Erasmus">
        <attvalues>
          <attvalue for="att1" value="1"/>
          <attvalue for="att2" value="#3C93AF"/>
          <attvalue for="att3" value="1"/>
        </attvalues>
        <viz:color r="60" g="147" b="175" a="1"/>
        <viz:position x="250" y="-121.827492660835" z="0"/>
        <viz:size value="125"/>
      </node>
    </nodes>
    <edges>
      <edge id="0" source="1" target="4" weight="1">
        <viz:color r="195" g="22" b="31" a="1"/>
      </edge>
      <edge id="1" source="3" target="2" weight="1">
        <viz:color r="213" g="171" b="91" a="1"/>
      </edge>
    </edges>
  </graph>
</gexf>

