  <meta lastmodifieddate="2026-07-03">
    <creator>Gephi 0.11.2</creator>
    <title></title>
    <description>A graph representing the intersection between Erasmus's and Budé's networks of correspondence in the year 1507</description>
  </meta>
  <graph defaultedgetype="directed" mode="static">
    <attributes class="node" mode="static">
      <attribute id="att1" title="Degree" type="float"/>
      <attribute id="att2" title="colour" type="string"/>
      <attribute id="att3" title="Weighted.Degree" type="float"/>
    </attributes>
    <nodes>
      <node id="1" label="Desiderius Erasmus">
        <attvalues>
          <attvalue for="att1" value="3.0"/>
          <attvalue for="att2" value="#3C93AF"/>
          <attvalue for="att3" value="4.0"/>
        </attvalues>
        <viz:size value="100.0"/>
        <viz:position x="148.56142" y="70.34108"/>
        <viz:color r="60" g="147" b="175"/>
      </node>
      <node id="4" label="Aldo Manuzio">
        <attvalues>
          <attvalue for="att1" value="1.0"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="2.0"/>
        </attvalues>
        <viz:size value="76.94423"/>
        <viz:position x="-215.43507" y="-102.004486"/>
        <viz:color r="82" g="82" b="82"/>
      </node>
      <node id="2" label="William Warham">
        <attvalues>
          <attvalue for="att1" value="1.0"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="1.0"/>
        </attvalues>
        <viz:size value="4.0"/>
        <viz:position x="-132.05765" y="229.51254"/>
        <viz:color r="82" g="82" b="82"/>
      </node>
      <node id="3" label="Henry VIII">
        <attvalues>
          <attvalue for="att1" value="1.0"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="1.0"/>
        </attvalues>
        <viz:size value="4.0"/>
        <viz:position x="93.848114" y="-247.60397"/>
        <viz:color r="82" g="82" b="82"/>
