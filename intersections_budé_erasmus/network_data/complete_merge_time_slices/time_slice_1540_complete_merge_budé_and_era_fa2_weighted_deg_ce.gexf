<?xml version='1.0' encoding='UTF-8'?>
<gexf xmlns="http://gexf.net/1.3" version="1.3" xmlns:viz="http://gexf.net/1.3/viz" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://gexf.net/1.3 http://gexf.net/1.3/gexf.xsd">
  <meta lastmodifieddate="2026-07-03">
    <creator>Gephi 0.11.2</creator>
    <title></title>
    <description>A graph representing the intersection between Erasmus's and Budé's networks of correspondence in the year 1540</description>
  </meta>
  <graph defaultedgetype="directed" mode="static">
    <attributes class="node" mode="static">
      <attribute id="att1" title="Degree" type="float"/>
      <attribute id="att2" title="colour" type="string"/>
      <attribute id="att3" title="Weighted.Degree" type="float"/>
    </attributes>
    <nodes>
      <node id="2" label="Guillaume Budé">
        <attvalues>
          <attvalue for="att1" value="2.0"/>
          <attvalue for="att2" value="#D5AB5B"/>
          <attvalue for="att3" value="2.0"/>
        </attvalues>
        <viz:size value="100.0"/>
        <viz:position x="-5.344452E-5" y="-5.344452E-5"/>
        <viz:color r="213" g="171" b="91"/>
      </node>
      <node id="1" label="Guy Morillon">
        <attvalues>
          <attvalue for="att1" value="1.0"/>
          <attvalue for="att2" value="#C3161F"/>
          <attvalue for="att3" value="1.0"/>
        </attvalues>
        <viz:size value="4.0"/>
        <viz:position x="147.25603" y="147.25603"/>
        <viz:color r="195" g="22" b="31"/>
      </node>
      <node id="3" label="Guillaume Poyet">
        <attvalues>
          <attvalue for="att1" value="1.0"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="1.0"/>
        </attvalues>
        <viz:size value="4.0"/>
        <viz:position x="-147.25615" y="-147.25615"/>
        <viz:color r="82" g="82" b="82"/>
      </node>
    </nodes>
    <edges>
      <edge id="0" source="2" target="1">
        <viz:color r="213" g="171" b="91"/>
      </edge>
      <edge id="1" source="2" target="3">
        <viz:color r="213" g="171" b="91"/>
      </edge>
    </edges>
  </graph>
</gexf>