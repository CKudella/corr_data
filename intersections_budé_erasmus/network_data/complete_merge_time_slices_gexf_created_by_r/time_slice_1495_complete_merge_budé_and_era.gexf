<?xml version="1.0" encoding="UTF-8"?>
<gexf xmlns="http://www.gexf.net/1.3" xmlns:viz="http://www.gexf.net/1.3/viz" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.gexf.net/1.3 http://www.gexf.net/1.3/gexf.xsd" version="1.3">
  <meta lastmodifieddate="2026-07-02">
    <creator>Christoph Kudella</creator>
    <description>A graph representing the intersection between Erasmus's and Budé's networks of correspondence in the year 1495</description>
    <keywords/>
  </meta>
  <graph mode="static" defaultedgetype="directed">
    <attributes class="node" mode="static">
      <attribute id="att1" title="Degree" type="float"/>
      <attribute id="att2" title="colour" type="string"/>
      <attribute id="att3" title="Weighted.Degree" type="float"/>
    </attributes>
    <nodes>
      <node id="1" label="Hector Boece">
        <attvalues>
          <attvalue for="att1" value="1"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="1"/>
        </attvalues>
        <viz:color r="82" g="82" b="82" a="1"/>
        <viz:position x="-173.605259059347" y="250" z="0"/>
        <viz:size value="12.5"/>
      </node>
      <node id="2" label="Desiderius Erasmus">
        <attvalues>
          <attvalue for="att1" value="4"/>
          <attvalue for="att2" value="#3C93AF"/>
          <attvalue for="att3" value="6"/>
        </attvalues>
        <viz:color r="60" g="147" b="175" a="1"/>
        <viz:position x="-91.8684192518838" y="-109.620423466477" z="0"/>
        <viz:size value="125"/>
      </node>
      <node id="3" label="Robert Gaguin">
        <attvalues>
          <attvalue for="att1" value="2"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="4"/>
        </attvalues>
        <viz:color r="82" g="82" b="82" a="1"/>
        <viz:position x="-250" y="-250" z="0"/>
        <viz:size value="111.512570389257"/>
      </node>
      <node id="4" label="Jacob Batt">
        <attvalues>
          <attvalue for="att1" value="1"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="1"/>
        </attvalues>
        <viz:color r="82" g="82" b="82" a="1"/>
        <viz:position x="250" y="-240.022195965658" z="0"/>
        <viz:size value="12.5"/>
      </node>
    </nodes>
    <edges>
      <edge id="0" source="2" target="1" weight="1">
        <viz:color r="60" g="147" b="175" a="1"/>
      </edge>
      <edge id="1" source="2" target="3" weight="1">
        <viz:color r="60" g="147" b="175" a="1"/>
      </edge>
      <edge id="2" source="2" target="4" weight="1">
        <viz:color r="60" g="147" b="175" a="1"/>
      </edge>
      <edge id="3" source="3" target="2" weight="3">
        <viz:color r="82" g="82" b="82" a="1"/>
      </edge>
    </edges>
  </graph>
</gexf>

