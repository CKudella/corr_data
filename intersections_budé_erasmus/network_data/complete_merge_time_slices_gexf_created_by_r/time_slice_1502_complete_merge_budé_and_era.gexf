          <attvalue for="att1" value="1"/>
          <attvalue for="att2" value="#525252"/>
          <attvalue for="att3" value="1"/>
        </attvalues>
        <viz:color r="82" g="82" b="82" a="1"/>
        <viz:position x="-250" y="-72.4599437647188" z="0"/>
        <viz:size value="10"/>
      </node>
      <node id="5" label="Edmond">
